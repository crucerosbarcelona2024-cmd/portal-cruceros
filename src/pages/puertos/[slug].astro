---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const puertosEntries = await getCollection('puertos');
  return puertosEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={entry.data.title} description={entry.data.description}>
    <article class="prose lg:prose-xl mx-auto">
        <h1 class="text-3xl font-bold text-blue-900 mb-2">{entry.data.title}</h1>
        <p class="text-sm text-gray-500 mb-8">Puerto: {entry.data.puerto} | País: {entry.data.pais}</p>

        <div class="bg-gray-100 text-center p-4 my-6 text-xs text-gray-400 border border-dashed rounded">
            [Anuncio AdSense - Contenido]
        </div>

        <div class="mt-4 text-gray-800 leading-relaxed">
            <Content />
        </div>

        <div class="bg-blue-50 border-l-4 border-blue-500 p-6 my-10 rounded-r">
            <h3 class="text-xl font-bold text-blue-900 mb-2">⚓ ¿Quieres esta guía en PDF para llevarla en el móvil?</h3>
            <p class="mb-4">Déjanos tu correo y te enviamos el itinerario detallado y los mapas de <strong>{entry.data.puerto}</strong>.</p>
            <form class="flex flex-col sm:flex-row gap-2">
                <input type="email" placeholder="Tu email" class="p-2 border rounded w-full">
                <button class="bg-blue-600 text-white px-4 py-2 rounded font-bold hover:bg-blue-700">Recibir PDF</button>
            </form>
        </div>
    </article>
</Layout>
