---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

// Esto lee automáticamente todos los archivos .md que has creado en la carpeta puertos
const puertos = await getCollection('puertos');
---

<Layout title="Guías de Puertos de Cruceros y Excursiones" description="Descarga gratis las guías en PDF de los puertos más importantes. Itinerarios, excursiones baratas y consejos para tu crucero.">
    
    <section class="text-center py-10">
        <h1 class="text-4xl font-bold text-blue-900 mb-4">Exprime al máximo las escalas de tu crucero 🚢</h1>
        <p class="text-xl text-gray-700 mb-8">Información real de cruceristas para cruceristas. Sin rodeos.</p>
        
        <div class="bg-white p-8 rounded-lg shadow-lg border-2 border-blue-500 max-w-2xl mx-auto mb-16">
            <h2 class="text-2xl font-bold text-red-600 mb-2">🎁 ¡Regalo para el grupo!</h2>
            <p class="text-gray-600 mb-6">Únete a nuestra lista y recibe la <strong>Guía Completa de Roma en PDF</strong> totalmente gratis para tu próximo crucero.</p>
            <form class="flex flex-col sm:flex-row gap-4 justify-center">
                <input type="email" placeholder="Tu mejor correo electrónico" required class="p-3 border border-gray-300 rounded-md w-full sm:w-2/3 focus:ring-2 focus:ring-blue-500">
                <button type="submit" class="bg-green-600 hover:bg-green-700 text-white font-bold py-3 px-6 rounded-md transition duration-300">
                    ¡Enviar Guía PDF!
                </button>
            </form>
        </div>

        <h2 class="text-2xl font-bold text-gray-800 mb-8 text-left border-b-2 border-blue-100 pb-2">Nuestras Guías de Escalas y Barcos</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-left">
            {puertos.map(puerto => (
                <article class="flex flex-col p-6 bg-white border border-gray-200 rounded-xl hover:shadow-xl transition-shadow duration-300">
                    <div class="flex-1">
                        <h3 class="text-xl font-bold text-blue-800 mb-3">{puerto.data.title}</h3>
                        <p class="text-gray-600 text-sm line-clamp-3 mb-4">{puerto.data.description}</p>
                    </div>
                    <a href={`/puertos/${puerto.slug}`} class="inline-flex items-center text-blue-600 font-bold hover:text-blue-800 transition-colors">
                        Leer guía completa 
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-1" viewBox="0 0 20 20" fill="currentColor">
                          <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                        </svg>
                    </a>
                </article>
            ))}
        </div>
    </section>

    <div class="bg-gray-100 text-center p-6 mt-16 text-sm text-gray-400 border border-dashed border-gray-300 rounded-lg">
        [Espacio reservado para Publicidad de Cruceros y Vuelos]
    </div>

</Layout>
